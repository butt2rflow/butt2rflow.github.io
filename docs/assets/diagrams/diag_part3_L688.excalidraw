    {
      "type": "text",
      "id": "el0722_7014",
      "x": 286.7,
      "y": 380.0,
      "width": 186.6,
      "height": 170,
      "text": "하나의 투자 원칙:\n\n장기 투자\n+ 충분한 현금 비중\n+ 기계적 리밸런싱\n+ 절대 과도한 베팅 X\n\n= 수학이 보장하는 구조적 우위",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#1e40af",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "seed": 609247,
      "version": 1,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "baseline": 14
    },
    {
      "type": "rectangle",
      "id": "el0723_4328",
      "x": 40,
      "y": 570,
      "width": 680,
      "height": 110,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f9fafb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
