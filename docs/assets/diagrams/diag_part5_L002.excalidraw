    {
      "type": "text",
      "id": "hv_details",
      "x": 80, "y": 140,
      "width": 260, "height": 90,
      "text": "과거 주가 데이터에서 계산\n후행(lagging) 지표\n복잡한 지식 불필요\n\n22거래일 일별 수익률의 표준편차\nx sqrt(252) = 연간 HV",
      "originalText": "과거 주가 데이터에서 계산\n후행(lagging) 지표\n복잡한 지식 불필요\n\n22거래일 일별 수익률의 표준편차\nx sqrt(252) = 연간 HV",
      "fontSize": 11, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 120013, "version": 1, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false,
      "containerId": null, "lineHeight": 1.25
    },

